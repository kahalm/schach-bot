# Discord Bot Token (von https://discord.com/developers/applications)
DISCORD_TOKEN=dein_token_hier

# Server-ID fuer DM-Berechtigungen (optional, 0 = deaktiviert)
# Wenn gesetzt, koennen Admins auch per DM Admin-Commands ausfuehren
GUILD_ID=0

# Discord Channel-ID wo täglich gepostet wird (Rechtsklick auf Channel → ID kopieren)
CHANNEL_ID=123456789012345678

# RookHub-Integration: Tages-/Zufalls-/Blindpuzzle kommen von RookHub, Links zeigen dorthin.
# API-URL für die Server-zu-Server-Calls (intern erreichbar reicht, KEIN Token nötig –
# die Lese-Endpoints sind anonym):
ROOKHUB_API_URL=http://rookhub-api:8080
# Öffentliche Frontend-URL für den anklickbaren Puzzle-Link (den die Discord-User öffnen):
ROOKHUB_WEB_URL=https://rookhub.example.com
# HMAC-Secret für die RookHub-Verknüpfung (/link, Begrüßungs-DM, private Puzzle-Links).
# MUSS exakt mit RookHubs Discord__LinkSecret übereinstimmen. Leer lassen → Feature inaktiv.
ROOKHUB_LINK_SECRET=change_me_shared_with_rookhub
# HMAC-Secret für den stats-basierten Motivations-DM (/motivation): liest den Trainings-/
# Puzzle-Fortschritt verknüpfter Spieler über GET /api/bot/player-progress.
# MUSS exakt mit RookHubs SchachBot__StatsSecret übereinstimmen. Leer lassen → /motivation inaktiv.
ROOKHUB_STATS_SECRET=change_me_shared_with_rookhub

# Lichess OAuth-Token (optional) – wird NICHT mehr fürs Puzzle-Posten verwendet
# (Puzzles laufen über RookHub). Nur noch für die /test-Diagnose relevant.
LICHESS_TOKEN=

# Ordner mit lokalen PGN-Dateien (für /puzzle, /kurs, /train, /blind, /endless)
BOOKS_DIR=books

# Uhrzeit für den täglichen Puzzle-Post (UTC!)
PUZZLE_HOUR=9
PUZZLE_MINUTE=0

# Discord Channel-ID fuer Turnier-Posts und Rallye-Erinnerungen (optional, 0 = deaktiviert)
TOURNAMENT_CHANNEL_ID=0

# Discord Channel-ID fuer woechentliche Wochenposts (Freitag 18:00 UTC, optional, 0 = deaktiviert)
WOCHENPOST_CHANNEL_ID=0

# Pfad zur index.txt mit allen Schachbuch-Dateien (z.B. von Syncthing)
# Wird für /bibliothek, /tag und /reindex benötigt
# Im Docker-Container: /app/library/index.txt (via Volume-Mount)
LIBRARY_INDEX=

# Claude API Key fuer KI-Chat (optional, ohne Key ist der Chat deaktiviert)
CLAUDE_API_KEY=

# Webhook-Empfaenger fuer RookHub-Solver-Events (Daily-Puzzle live updaten).
# WEBHOOK_SECRET muss identisch zu RookHubs SchachBot__WebhookSecret sein.
# Leer = Webhook deaktiviert (Bot ruft beim Start einmal refresh() auf — Catch-up).
WEBHOOK_BIND_HOST=0.0.0.0
WEBHOOK_PORT=9000
WEBHOOK_SECRET=

# SFTPGo-Integration für Dateien über dem Discord-Upload-Limit (8 MB)
# Einmalig im SFTPGo-Admin einen Share anlegen (kein Ablaufdatum, mit Passwort),
# der das Bibliotheksverzeichnis abdeckt. Die ID aus der Admin-Oberfläche kopieren.
# Ohne diese Variablen erscheint bei großen Dateien nur eine Fehlermeldung.
SFTPGO_BASE_URL=https://files.example.com
SFTPGO_SHARE_ID=
SFTPGO_SHARE_PASSWORD=

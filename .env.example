# Discord Bot Token (von https://discord.com/developers/applications)
DISCORD_TOKEN=dein_token_hier

# Lichess Study ID (aus der URL: lichess.org/study/STUDY_ID)
LICHESS_STUDY_ID=ndPgby4a

# Discord Channel-ID wo täglich gepostet wird (Rechtsklick auf Channel → ID kopieren)
CHANNEL_ID=123456789012345678

# Uhrzeit für den täglichen Studie-Post (UTC!)
POST_HOUR=8
POST_MINUTE=0

# Lichess OAuth-Token (optional)
# Ohne Token:  öffentlicher /api/import (kein Study-Upload möglich)
# Mit Token:   Study-Upload (Scope: study:write) + Account-Zuordnung
LICHESS_TOKEN=

# Lichess Study-ID für den täglichen Puzzle-Upload (optional)
# Wenn gesetzt: Puzzle wird als Kapitel in diese Studie importiert → klickbarer Link
# Voraussetzung: LICHESS_TOKEN mit study:write Scope
# Study vorher auf lichess.org anlegen: lichess.org/study/new
PUZZLE_STUDY_ID=

# Ordner mit lokalen PGN-Dateien für das tägliche Puzzle
BOOKS_DIR=books

# Uhrzeit für den täglichen Puzzle-Post (UTC!)
PUZZLE_HOUR=9
PUZZLE_MINUTE=0
